# ================================================================
#  Multi-Agent Medical Chatbot — Environment Configuration
#  Copy this file: cp .env.example .env  then fill in your keys
# ================================================================

# ── OpenAI (LLM + Embeddings + Speech) ──────────────────────────
OPENAI_API_KEY=sk-...your-openai-api-key...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Database (Qdrant) ─────────────────────────────────────
# Leave blank to use local Qdrant storage (default)
QDRANT_URL=
QDRANT_API_KEY=

# ── Web Search ───────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...your-tavily-key...

# ── Speech (OpenAI Whisper + TTS — uses same OPENAI_API_KEY above) ──
# No extra key needed

# ── HuggingFace (for reranker model download) ────────────────────
HUGGINGFACE_TOKEN=hf_...your-huggingface-token...
